; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via a text editor.

[application]

config/name="Sage of City N"
run/main_scene="res://scenes/main/main_menu.tscn"
config/features=PackedStringArray("4.3")

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
SettingsManager="*res://scripts/autoload/settings_manager.gd"
ContentLoader="*res://scripts/autoload/content_loader.gd"
VisitorManager="*res://scripts/systems/visitor_manager.gd"
DayCycle="*res://scripts/systems/day_cycle.gd"
ConsequenceEngine="*res://scripts/systems/consequence_engine.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
